{
  "name": "agentify",
  "version": "0.4.0",
  "description": "Provider-neutral repo memory and intelligence for coding agents. Switch between Claude Code, Codex, and MCP clients without losing durable project context.",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "license": "MIT",
  "bin": {
    "agentify": "./src/cli.js"
  },
  "files": [
    "src/**/*.js",
    "src/**/*.mjs",
    "skills/",
    "README.md",
    "docs/",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/main.js"
  },
  "scripts": {
    "test": "node --test test/*.test.js",
    "lint": "eslint .",
    "bench:analyze": "AGENTIFY_BENCH=1 node --test test/session-analysis-bench.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agent",
    "codex",
    "claude",
    "gemini",
    "opencode",
    "cli",
    "documentation",
    "metadata",
    "validation",
    "orchestration",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ixigo/agentify.git"
  },
  "homepage": "https://github.com/ixigo/agentify",
  "bugs": {
    "url": "https://github.com/ixigo/agentify/issues"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3",
    "yocto-spinner": "^1.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0"
  }
}
