{
  "name": "agentify",
  "version": "0.3.0",
  "description": "Lightweight context tracking and repo intelligence for AI coding agents. Install once per repo: it wires Claude Code (hooks + CLAUDE.md) to use Agentify internally for context tracking, structural queries, and risk analysis.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "agentify": "./src/cli.js"
  },
  "files": [
    "src/**/*.js",
    "skills/",
    "README.md",
    "docs/",
    "LICENSE"
  ],
  "exports": {
    ".": "./src/main.js"
  },
  "scripts": {
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "agent",
    "codex",
    "claude",
    "gemini",
    "opencode",
    "cli",
    "documentation",
    "metadata",
    "validation",
    "orchestration",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ixigo/agentify.git"
  },
  "homepage": "https://github.com/ixigo/agentify",
  "bugs": {
    "url": "https://github.com/ixigo/agentify/issues"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1",
    "typescript": "^6.0.2",
    "yaml": "^2.8.3",
    "yocto-spinner": "^1.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
