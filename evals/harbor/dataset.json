{
  "schema": "harbor-dataset-v1",
  "name": "agentify-context-bench",
  "version": "1.0.0",
  "model": "anthropic/claude-haiku-4-5-20251001",
  "pins": {
    "harbor": "0.2.1",
    "claude_code": "2.0.21",
    "agentify": "0.4.0"
  },
  "agents": [
    {
      "name": "agentify-claude",
      "kind": "installed",
      "import_path": "agents.agentify_claude:AgentifyClaudeAgent"
    },
    {
      "name": "claude-code",
      "kind": "builtin"
    }
  ],
  "tasks": [
    {
      "id": "recall-error-envelope",
      "category": "decision-recall",
      "max_cost_usd": 0.3,
      "answer_leak_patterns": ["order_not_found", "getOrder", "orders/"]
    },
    {
      "id": "avoid-cache-regression",
      "category": "prior-failure-avoidance",
      "max_cost_usd": 0.3,
      "answer_leak_patterns": ["maxEntries", "evictOldest", "cache.clear()"]
    },
    {
      "id": "reject-stale-config-path",
      "category": "stale-context-rejection",
      "max_cost_usd": 0.3,
      "answer_leak_patterns": ["retry_limit: 5", "retryLimit: 5"]
    },
    {
      "id": "rename-shipping-rate-refs",
      "category": "repo-intelligence",
      "max_cost_usd": 0.35,
      "answer_leak_patterns": ["quoteShippingRate"]
    },
    {
      "id": "select-affected-tests",
      "category": "affected-test-selection",
      "max_cost_usd": 0.3,
      "answer_leak_patterns": ["Math.round((subtotal", "roundHalfUp"]
    },
    {
      "id": "mechanical-header-bump",
      "category": "mechanical-control",
      "max_cost_usd": 0.25,
      "answer_leak_patterns": ["Copyright 2026"]
    },
    {
      "id": "misleading-note-paginate",
      "category": "misleading-context",
      "max_cost_usd": 0.3,
      "answer_leak_patterns": ["(page - 1) * pageSize", "pageIndex - 1"]
    },
    {
      "id": "timezone-flake-gotcha",
      "category": "prior-failure-avoidance",
      "max_cost_usd": 0.3,
      "answer_leak_patterns": ["getUTCFullYear", "toISOString().slice(0, 10)"]
    }
  ],
  "suites": {
    "smoke": {
      "tasks": ["recall-error-envelope"],
      "attempts": 1
    },
    "nightly": {
      "tasks": [
        "recall-error-envelope",
        "avoid-cache-regression",
        "reject-stale-config-path",
        "rename-shipping-rate-refs",
        "select-affected-tests",
        "mechanical-header-bump",
        "misleading-note-paginate",
        "timezone-flake-gotcha"
      ],
      "attempts": 3
    },
    "profiles": {
      "tasks": [
        "recall-error-envelope",
        "avoid-cache-regression",
        "reject-stale-config-path",
        "rename-shipping-rate-refs",
        "select-affected-tests",
        "mechanical-header-bump",
        "misleading-note-paginate",
        "timezone-flake-gotcha"
      ],
      "attempts": 3,
      "agents": 4
    }
  }
}
